<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="ShiftSync.Mobile.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:ShiftSync.Mobile.Views"
       Title="ShiftSync"
       FlyoutBehavior="Flyout">

    <FlyoutItem Title="Account">
        <ShellContent Title="Login"
                      Route="LoginPage"
                      ContentTemplate="{DataTemplate views:LoginPage}" />
        <ShellContent Title="Join Business"
                      Route="JoinBusinessPage"
                      ContentTemplate="{DataTemplate views:JoinBusinessPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Employee">
        <ShellContent Title="Availability"
                      Route="AvailabilityPage"
                      ContentTemplate="{DataTemplate views:AvailabilityPage}" />
        <ShellContent Title="My Shifts"
                      Route="ShiftsPage"
                      ContentTemplate="{DataTemplate views:ShiftsPage}" />
        <ShellContent Title="Payroll"
                      Route="PayrollPage"
                      ContentTemplate="{DataTemplate views:PayrollPage}" />
    </FlyoutItem>
</Shell>
