<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShiftSync.Mobile.Views.JoinBusinessPage"
             Title="Join Business">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Join Business as Employee"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding HasError}" Value="True">
                        <Setter Property="TextColor" Value="Red" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding HasError}" Value="False">
                        <Setter Property="TextColor" Value="Green" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>

            <Entry Placeholder="Company Code" Text="{Binding CompanyCode}" />
            <Entry Placeholder="Full Name" Text="{Binding FullName}" />
            <Entry Placeholder="Email" Keyboard="Email" Text="{Binding Email}" />
            <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}" />

            <Button Text="Create Employee Account" Command="{Binding RegisterEmployeeCommand}" />
            <Button Text="Back to Login" Command="{Binding GoToLoginCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
