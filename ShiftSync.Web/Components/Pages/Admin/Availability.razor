@page "/admin/availability"
@inject SessionState Session
@inject ApiClient ApiClient

<section class="page-stack rise-in">
    <div class="flex flex-wrap items-end justify-between gap-3">
        <div class="glass-card flex-1">
            <h1 class="page-title">Availability Viewer</h1>
            <p class="page-subtitle">Review each team member's weekly availability windows.</p>
        </div>
        <button class="btn-secondary shrink-0" @onclick="LoadAsync" disabled="@IsBusy">Refresh</button>
    </div>

    @if (!Session.IsAdmin)
    {
        <div class="notice error">Admin access is required.</div>
    }
    else
    {
        if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="notice error">@ErrorMessage</div>
        }

        @if (IsBusy)
        {
            <div class="glass-card text-sm text-slate-600">Loading availability...</div>
        }
        else if (Slots.Count == 0)
        {
            <div class="glass-card text-sm text-slate-600">No employee availability found.</div>
        }
        else
        {
            @foreach (var group in Slots.GroupBy(x => x.EmployeeName).OrderBy(x => x.Key))
            {
                <div class="glass-card space-y-3">
                    <div class="flex items-center justify-between">
                        <h3 class="font-display text-2xl font-semibold text-slate-900">@group.Key</h3>
                        <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">@group.Count() slots</span>
                    </div>

                    <div class="table-shell">
                        <table>
                            <thead>
                                <tr>
                                    <th>Day</th>
                                    <th>Start</th>
                                    <th>End</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var slot in group.OrderBy(x => x.DayOfWeek).ThenBy(x => x.StartTime))
                                {
                                    <tr>
                                        <td>@ToDayName(slot.DayOfWeek)</td>
                                        <td>@slot.StartTime</td>
                                        <td>@slot.EndTime</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
</section>

@code {
    private List<AvailabilityDto> Slots { get; set; } = [];
    private bool IsBusy { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsAdmin)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;

        try
        {
            Slots = await ApiClient.GetAdminAvailabilityAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private static string ToDayName(int day)
        => Enum.IsDefined(typeof(DayOfWeek), day)
            ? ((DayOfWeek)day).ToString()
            : "Unknown";
}
