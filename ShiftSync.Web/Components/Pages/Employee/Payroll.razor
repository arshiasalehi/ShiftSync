@page "/employee/payroll"
@inject SessionState Session
@inject ApiClient ApiClient

<section class="page-stack rise-in">
    <div class="glass-card">
        <h1 class="page-title">Payroll Estimate</h1>
        <p class="page-subtitle">Your projected weekly pay from published shifts.</p>
    </div>

    @if (!Session.IsEmployee)
    {
        <div class="notice error">Employee access is required.</div>
    }
    else
    {
        if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="notice @(HasError ? "error" : "success")">@StatusMessage</div>
        }

        <div class="glass-card space-y-3">
            <div>
                <label class="field-label">Week Start Date</label>
                <input class="input-shell max-w-xs" @bind="WeekStartDateText" />
            </div>
            <button class="btn-secondary" @onclick="LoadAsync" disabled="@IsBusy">Load Payroll</button>
        </div>

        @if (PayrollData is not null)
        {
            <div class="glass-card space-y-3">
                <div class="grid gap-3 md:grid-cols-2">
                    <div class="rounded-xl border border-slate-200/80 bg-white/70 p-3">
                        <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Employee</p>
                        <p class="mt-1 font-semibold text-slate-900">@PayrollData.EmployeeName</p>
                    </div>
                    <div class="rounded-xl border border-slate-200/80 bg-white/70 p-3">
                        <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Week Start</p>
                        <p class="mt-1 font-semibold text-slate-900">@PayrollData.WeekStartDate.ToString("yyyy-MM-dd")</p>
                    </div>
                    <div class="rounded-xl border border-slate-200/80 bg-white/70 p-3">
                        <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Total Hours</p>
                        <p class="mt-1 font-semibold text-slate-900">@PayrollData.TotalHours</p>
                    </div>
                    <div class="rounded-xl border border-slate-200/80 bg-white/70 p-3">
                        <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Hourly Rate</p>
                        <p class="mt-1 font-semibold text-slate-900">@PayrollData.HourlyRate.ToString("C")</p>
                    </div>
                </div>

                <div class="value-emphasis">
                    <p class="text-xs uppercase tracking-[0.12em] text-orange-100">Estimated Weekly Pay</p>
                    <p class="mt-1 font-display text-3xl font-semibold">@PayrollData.TotalEstimatedPay.ToString("C")</p>
                </div>
            </div>
        }
    }
</section>

@code {
    private PayrollEstimateDto? PayrollData { get; set; }
    private bool IsBusy { get; set; }
    private bool HasError { get; set; }
    private string StatusMessage { get; set; } = string.Empty;

    private DateTime WeekStartDate { get; set; } = NormalizeWeekStart(DateTime.Today);

    private string WeekStartDateText
    {
        get => WeekStartDate.ToString("yyyy-MM-dd");
        set
        {
            if (DateTime.TryParse(value, out var date))
            {
                WeekStartDate = NormalizeWeekStart(date);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsEmployee)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        IsBusy = true;
        HasError = false;
        StatusMessage = string.Empty;

        try
        {
            PayrollData = await ApiClient.GetMyPayrollAsync(WeekStartDate);
            StatusMessage = "Payroll loaded.";
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
            PayrollData = null;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private static DateTime NormalizeWeekStart(DateTime date)
    {
        var value = date.Date;
        var offset = ((int)value.DayOfWeek + 6) % 7;
        return value.AddDays(-offset);
    }
}
