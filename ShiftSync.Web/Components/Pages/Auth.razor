@page "/auth"
@inject ApiClient ApiClient
@inject SessionState Session
@inject NavigationManager Navigation

<section class="page-stack rise-in">
    <div class="glass-card">
        <p class="shell-kicker">Account Access</p>
        <h1 class="page-title">Sign In, Create Your Admin Workspace, Or Join A Team</h1>
        <p class="page-subtitle">Choose the right entry point for your restaurant role and continue into ShiftSync.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="notice @(HasError ? "error" : "success")">@StatusMessage</div>
    }

    <div class="grid gap-4 xl:grid-cols-3">
        <div class="glass-card space-y-3">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined rounded-lg bg-slate-900 p-2 text-white">person</span>
                <div>
                    <p class="metric-label">Welcome Back</p>
                    <h3 class="font-display text-xl font-semibold text-slate-900">Employee Login</h3>
                </div>
            </div>

            <div>
                <label class="field-label">Email</label>
                <input class="input-shell" @bind="LoginModel.Email" />
            </div>

            <div>
                <label class="field-label">Password</label>
                <input class="input-shell" type="password" @bind="LoginModel.Password" />
            </div>

            <button class="btn-primary w-full" @onclick="LoginAsync" disabled="@IsBusy">
                @(IsBusy ? "Please wait..." : "Login")
            </button>
        </div>

        <div class="glass-card space-y-3">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined rounded-lg bg-amber-100 p-2 text-amber-700">business_center</span>
                <div>
                    <p class="metric-label">For Employers</p>
                    <h3 class="font-display text-xl font-semibold text-slate-900">Register Admin</h3>
                </div>
            </div>

            <div>
                <label class="field-label">Business Name</label>
                <input class="input-shell" @bind="RegisterAdminModel.BusinessName" />
            </div>

            <div>
                <label class="field-label">Full Name</label>
                <input class="input-shell" @bind="RegisterAdminModel.FullName" />
            </div>

            <div>
                <label class="field-label">Email</label>
                <input class="input-shell" @bind="RegisterAdminModel.Email" />
            </div>

            <div>
                <label class="field-label">Password</label>
                <input class="input-shell" type="password" @bind="RegisterAdminModel.Password" />
            </div>

            <button class="btn-primary w-full" @onclick="RegisterAdminAsync" disabled="@IsBusy">
                Create Admin Account
            </button>
        </div>

        <div class="glass-card space-y-3">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined rounded-lg bg-emerald-100 p-2 text-emerald-700">group_add</span>
                <div>
                    <p class="metric-label">For Team Members</p>
                    <h3 class="font-display text-xl font-semibold text-slate-900">Join Business</h3>
                </div>
            </div>

            <div>
                <label class="field-label">Company Code</label>
                <input class="input-shell" @bind="RegisterEmployeeModel.CompanyCode" />
            </div>

            <div>
                <label class="field-label">Full Name</label>
                <input class="input-shell" @bind="RegisterEmployeeModel.FullName" />
            </div>

            <div>
                <label class="field-label">Email</label>
                <input class="input-shell" @bind="RegisterEmployeeModel.Email" />
            </div>

            <div>
                <label class="field-label">Password</label>
                <input class="input-shell" type="password" @bind="RegisterEmployeeModel.Password" />
            </div>

            <button class="btn-secondary w-full" @onclick="RegisterEmployeeAsync" disabled="@IsBusy">
                Join Business
            </button>
        </div>
    </div>
</section>

@code {
    private LoginRequest LoginModel { get; } = new();
    private RegisterAdminRequest RegisterAdminModel { get; } = new();
    private RegisterEmployeeRequest RegisterEmployeeModel { get; } = new();

    private bool IsBusy { get; set; }
    private bool HasError { get; set; }
    private string StatusMessage { get; set; } = string.Empty;

    private async Task LoginAsync()
    {
        await ExecuteAsync(async () =>
        {
            var response = await ApiClient.LoginAsync(LoginModel);
            Session.SetUser(response);
            NavigateByRole(response.Role);
        });
    }

    private async Task RegisterAdminAsync()
    {
        await ExecuteAsync(async () =>
        {
            var response = await ApiClient.RegisterAdminAsync(RegisterAdminModel);
            Session.SetUser(response);
            NavigateByRole(response.Role);
        });
    }

    private async Task RegisterEmployeeAsync()
    {
        await ExecuteAsync(async () =>
        {
            var response = await ApiClient.RegisterEmployeeAsync(RegisterEmployeeModel);
            Session.SetUser(response);
            NavigateByRole(response.Role);
        });
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        IsBusy = true;
        HasError = false;
        StatusMessage = string.Empty;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void NavigateByRole(string role)
    {
        var path = role == UserRoles.Admin
            ? "/admin/dashboard"
            : "/employee/shifts";

        Navigation.NavigateTo(path);
    }
}
