@page "/"
@inject SessionState Session

<section class="page-stack rise-in">
    <div class="glass-card">
        <p class="shell-kicker">Restaurant Workforce Operating System</p>
        <h1 class="page-title">Plan Weekly Staffing Without The Group-Chat Chaos</h1>
        <p class="page-subtitle max-w-3xl">
            ShiftSync keeps employee availability, shift planning, and payroll estimation in one production-ready workspace for managers and staff.
        </p>
    </div>

    <div class="metric-grid md:grid-cols-3">
        <div class="metric-card">
            <p class="metric-label">Workflow</p>
            <p class="metric-value">Availability -> Schedule -> Payroll</p>
            <p class="page-subtitle">One loop, one source of truth, every week.</p>
        </div>
        <div class="metric-card">
            <p class="metric-label">Guardrails</p>
            <p class="metric-value">Conflict Checks Built-In</p>
            <p class="page-subtitle">Prevent double-booking and overlap before publish.</p>
        </div>
        <div class="metric-card">
            <p class="metric-label">Audience</p>
            <p class="metric-value">Admin + Employee Views</p>
            <p class="page-subtitle">Role-based experiences powered by the same backend.</p>
        </div>
    </div>

    @if (!Session.IsAuthenticated)
    {
        <div class="glass-card">
            <p class="metric-label">Get Started</p>
            <h3 class="font-display text-2xl font-bold text-slate-900">Create your account or join your restaurant team.</h3>
            <p class="page-subtitle">Use Login / Register to open an admin account or onboard with a company code.</p>
            <div class="mt-4 flex flex-wrap gap-2">
                <a class="btn-primary" href="/auth">Open Login / Register</a>
            </div>
        </div>
    }
    else if (Session.IsAdmin)
    {
        <div class="glass-card">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                    <p class="metric-label">Welcome Back</p>
                    <h3 class="font-display text-2xl font-bold text-slate-900">@Session.CurrentUser!.FullName</h3>
                    <p class="page-subtitle">Open dashboard, review availability, publish schedule, then run payroll.</p>
                </div>
                <a class="btn-primary" href="/admin/dashboard">Go To Admin Dashboard</a>
            </div>
        </div>
    }
    else
    {
        <div class="glass-card">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                    <p class="metric-label">Welcome Back</p>
                    <h3 class="font-display text-2xl font-bold text-slate-900">@Session.CurrentUser!.FullName</h3>
                    <p class="page-subtitle">Update your weekly availability, check assigned shifts, and track estimated pay.</p>
                </div>
                <a class="btn-primary" href="/employee/shifts">Open My Shifts</a>
            </div>
        </div>
    }
</section>
