@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="page-stack rise-in">
    <div class="glass-card space-y-3">
        <h1 class="page-title text-red-700">Something Went Wrong</h1>
        <h2 class="text-lg font-semibold text-red-800">An error occurred while processing your request.</h2>

        @if (ShowRequestId)
        {
            <p class="text-sm text-slate-700">
                <strong>Request ID:</strong> <code>@RequestId</code>
            </p>
        }

        <div class="rounded-xl border border-red-200 bg-red-50/70 p-3 text-sm text-red-900">
            <p class="font-semibold">Development mode note</p>
            <p class="mt-1">Switch to <strong>Development</strong> environment to view full diagnostics for local debugging only.</p>
        </div>
    </div>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
